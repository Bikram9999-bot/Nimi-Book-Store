jQuery(function ($) {
    var visited = $.cookie('visited');
    if (visited !== 'yes') {
        setTimeout(function () {
            Fancybox.show([
                {
                    src: "#inline",
                    type: "inline"
                }
            ], {
                dragToClose: false,
                closeButton: true
            });
        }, 500);
        $.cookie('visited', 'yes', {
            expires: 1,
            path: '/'
        });
    }
});
</script>
